# ─── Database ────────────────────────────────────────────────────────────────
# Get a free PostgreSQL database from: https://neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/shaadibio?sslmode=require"

# ─── Razorpay (https://dashboard.razorpay.com) ───────────────────────────────
# Use test keys during development, live keys for production
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"
# Public key — safe to expose in browser
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXXXX"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://shaadibio.vercel.app"

# ─── Vercel auto-sets this in production ─────────────────────────────────────
# VERCEL=1
